# ─────────────────────────────────────────────────────────────────────
# DocSign — docker-compose environment template
# ─────────────────────────────────────────────────────────────────────
# 1. Copy:    cp .env.example .env
# 2. Edit:    set POSTGRES_PASSWORD + JWT_SECRET (required)
# 3. Run:     docker compose up -d --build
# ─────────────────────────────────────────────────────────────────────

# ===== Mode ==========================================================
# `production` enables Secure cookies (HTTPS-only) → put a TLS proxy in
# front of this stack OR set NODE_ENV=development for local plain-HTTP test.
NODE_ENV=production
LOG_LEVEL=info

# ===== Database ======================================================
POSTGRES_DB=docsign
POSTGRES_USER=docsign
# CHANGE THIS — at least 16 random chars. Compose refuses to start if blank.
POSTGRES_PASSWORD=change-me-to-a-strong-random-string

# ===== Backend =======================================================
# Generate with:  openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=8h

# Public URL of the FRONTEND — used for CORS allowlist + email links.
FRONTEND_URL=http://localhost:3000

# SMTP — defaults to Office365 STARTTLS on port 587. Override for any other
# provider (Gmail Workspace, SendGrid, internal relay). Leave USER/PASS blank
# to skip notifications entirely (API still works, no email goes out).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Reverse-proxy hops. Set this RIGHT — wrong value breaks rate limiting +
# audit log IPs. 1 = single nginx/Traefik in front (default). 2 = double-proxy
# like Cloudflare → ALB → app.
TRUST_PROXY=1

# Audit log retention in days. Older rows deleted by `npm run audit:cleanup`
# (run from cron daily). Floor is 30; script refuses smaller values.
AUDIT_RETENTION_DAYS=365

# Host port to expose the API on. Pick something else if 5000 is taken.
BACKEND_PORT=5000

# Graceful shutdown timeouts (milliseconds). All defaults are sensible —
# only override if you change orchestrator probe periods.
#   drain delay  : time to keep serving after SIGTERM so LB can depool
#   request wait : max wait for in-flight HTTP requests to finish
#   db wait      : max wait for PG pool to close cleanly
#   force exit   : overall ceiling — process is killed past this
# Sum of (drain + request + db) should comfortably fit inside the
# orchestrator's terminationGracePeriodSeconds (k8s default 30s).
SHUTDOWN_DRAIN_DELAY_MS=5000
SHUTDOWN_REQUEST_TIMEOUT_MS=10000
SHUTDOWN_DB_TIMEOUT_MS=5000
SHUTDOWN_FORCE_EXIT_MS=20000

# ===== Frontend ======================================================
# URL the BROWSER uses to reach the backend. NOT the internal docker DNS.
# Behind a reverse proxy in real production this becomes:
#   NEXT_PUBLIC_API_URL=https://api.docsign.example.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api
FRONTEND_PORT=3000
