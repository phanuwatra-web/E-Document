# syntax=docker/dockerfile:1.7
# ─────────────────────────────────────────────────────────────────────
# DocSign Frontend — multi-stage Next.js 16 standalone build
# ─────────────────────────────────────────────────────────────────────
# Stage 1: deps    — install all (incl. dev) deps for the build
# Stage 2: builder — `next build` produces .next/standalone
# Stage 3: runner  — copies only the standalone server + static assets
#
# Final image: ~150 MB instead of ~700 MB if we shipped node_modules.
# ─────────────────────────────────────────────────────────────────────

# ===== Stage 1: deps =====================================================
FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci --no-audit --no-fund

# ===== Stage 2: builder ===================================================
FROM node:20-alpine AS builder
WORKDIR /app

# NEXT_PUBLIC_* vars are inlined into the client bundle at BUILD time, not
# runtime. They MUST be passed as a build arg or the SPA will fall back to
# the default `http://localhost:5000/api`.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    NEXT_TELEMETRY_DISABLED=1 \
    NODE_ENV=production

COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

# ===== Stage 3: runner ====================================================
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# wget for HEALTHCHECK (alpine has no curl).
RUN apk add --no-cache wget && \
    addgroup -S app && adduser -S app -G app

# `output: 'standalone'` in next.config.js produces this folder structure.
# We copy ONLY what the runtime needs — never the original source or
# the full node_modules.
COPY --from=builder --chown=app:app /app/.next/standalone ./
COPY --from=builder --chown=app:app /app/.next/static    ./.next/static
# `public/` is optional — guard with a Dockerfile no-op if absent (we
# don't have a public folder yet, but if added later the COPY just works).

USER app
EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD wget -q --spider --tries=1 http://localhost:3000/ || exit 1

# Standalone server entrypoint generated by Next.js build.
CMD ["node", "server.js"]
