PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/docsign

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=8h

# SMTP — defaults to Office365 STARTTLS on port 587. Override for other
# providers. SMTP_SECURE=true uses implicit TLS (port 465).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@company.com
SMTP_PASS=your_outlook_password

# Frontend URL (for email links & CORS)
FRONTEND_URL=http://localhost:3000

# Reverse-proxy hop count. Set to the number of trusted proxies between the
# Internet and this app. Wrong value breaks rate limiting and audit IPs.
#   1  = direct nginx/Traefik (default)
#   2  = Cloudflare → ALB → app
#   0  = no proxy (local dev)
TRUST_PROXY=1

# Audit log retention in days. Older rows are deleted by `npm run audit:cleanup`
# (run from cron daily). Floor is 30 (script refuses lower).
AUDIT_RETENTION_DAYS=365
