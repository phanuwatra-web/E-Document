# Copy to .env.test for local test runs:
#   cp .env.test.example .env.test
#
# CI passes these via GitHub Actions secrets / GitLab CI vars instead of a file.

NODE_ENV=test
LOG_LEVEL=silent

# CRITICAL: must point to a SEPARATE database. Tests TRUNCATE all tables
# before every test — pointing at dev/prod here would wipe real data.
# The test bootstrap also refuses to run if the DB name doesn't contain
# the substring "test" (see tests/setup/env.js).
DATABASE_URL=postgresql://docsign:test1234@localhost:5432/docsign_test

# Any 32+ char string is fine for tests; doesn't need real entropy.
JWT_SECRET=test-jwt-secret-at-least-32-characters-long-for-tests
JWT_EXPIRES_IN=1h

FRONTEND_URL=http://localhost:3000
